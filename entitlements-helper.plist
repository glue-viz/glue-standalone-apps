<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Entitlements for the bundled QtWebEngineProcess.app helper in the sandboxed
  App Store build.

  Qt launches QtWebEngineProcess as a separate executable. com.apple.security.inherit
  makes the helper inherit the parent app's sandbox rather than defining its own
  resource access; this is the combination Qt documents for QtWebEngineProcess on
  the Mac App Store.

  Note: there is deliberately no application-group entitlement here. Older Qt
  guidance used an app group for the helper's mach-port IPC; if the WWT viewer
  fails under the sandbox with an IPC error, re-add
  com.apple.security.application-groups here and in entitlements-appstore.plist.
-->
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.inherit</key>
	<true/>
</dict>
</plist>
