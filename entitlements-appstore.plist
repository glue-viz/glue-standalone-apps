<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Entitlements for the Mac App Store build of glue (sandboxed).

  This is intentionally separate from entitlements.plist, which is used for the
  Developer ID / DMG build. The DMG build uses the hardened runtime and is NOT
  sandboxed; the App Store build is sandboxed and does not need the cs.* hardened
  runtime exceptions.

  __TEAM_ID__ is substituted with the Apple Developer Team ID by
  osx/sign_app_store.sh at signing time. The application group is what lets the
  sandboxed main app and the QtWebEngineProcess helper talk to each other over
  mach ports (see osx/sign_app_store.sh and entitlements-helper.plist).
-->
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>__TEAM_ID__.io.gluesolutions.glueviz</string>
	</array>
	<!-- glue loads data over the network (HiPS, WWT, remote catalogues). -->
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- pywwt / the embedded notebook serve content over a local loopback port. -->
	<key>com.apple.security.network.server</key>
	<true/>
	<!-- Open and save .glu session files and exported data chosen by the user. -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
</dict>
</plist>
