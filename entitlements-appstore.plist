<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Entitlements for the Mac App Store build of glue (sandboxed).

  This is intentionally separate from entitlements.plist, which is used for the
  Developer ID / DMG build. The DMG build uses the hardened runtime and is NOT
  sandboxed; the App Store build is sandboxed and does not need the cs.* hardened
  runtime exceptions.

  The application-identifier and team-identifier must match the embedded
  provisioning profile and the App ID, otherwise the build is not eligible for
  TestFlight. (Xcode injects these automatically; we sign by hand so we set them
  here.) __TEAM_ID__ is substituted with the Apple Developer Team ID by
  osx/sign_app_store.sh at signing time.

  Note: there is deliberately no application-group entitlement here. It is only
  needed if QtWebEngine's helper IPC turns out to require it under the sandbox;
  if the WWT viewer fails with a mach-port/IPC error, re-add
  com.apple.security.application-groups (matching entitlements-helper.plist),
  register the group in the Developer portal, and include it in the profile.
-->
<plist version="1.0">
<dict>
	<key>com.apple.application-identifier</key>
	<string>__TEAM_ID__.io.gluesolutions.glueviz</string>
	<key>com.apple.developer.team-identifier</key>
	<string>__TEAM_ID__</string>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<!-- glue loads data over the network (HiPS, WWT, remote catalogues). -->
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- pywwt / the embedded notebook serve content over a local loopback port. -->
	<key>com.apple.security.network.server</key>
	<true/>
	<!-- Open and save .glu session files and exported data chosen by the user. -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
</dict>
</plist>
